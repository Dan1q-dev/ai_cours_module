OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.2
EMBEDDING_MODEL=text-embedding-3-small
AI_VECTOR_DIMENSION=1536
AI_VECTOR_TOP_K=6
AI_VECTOR_CANDIDATE_MULTIPLIER=4
PUBLIC_API_BASE_URL=http://localhost:3000
AI_DB_PROVIDER=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/course_ai_tutor?schema=public
AI_DB_PATH=data/ai-module.db
AI_TELEMETRY_RETENTION_DAYS=30
AI_DB_CLEANUP_EVERY_REQUESTS=25
AI_RPM_LIMIT=30
AI_DAILY_REQUEST_LIMIT=500
AI_DAILY_TOKEN_LIMIT=750000
AI_MONTHLY_COST_USD_LIMIT=100
AI_MAX_INPUT_CHARS=1200
AI_MAX_HISTORY_MESSAGES=12
AI_MATERIAL_MAX_BYTES=52428800
OPENAI_CHAT_PROMPT_COST_PER_1K=0.00015
OPENAI_CHAT_COMPLETION_COST_PER_1K=0.0006
OPENAI_EMBED_COST_PER_1K=0.00002

# Optional Redis fast-path for quota cache/job state
AI_REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
AI_REDIS_PREFIX=ai
AI_REDIS_CONNECT_TIMEOUT_MS=3000
AI_QUOTA_MINUTE_TTL_SEC=120
AI_QUOTA_DAY_TTL_SEC=259200
AI_QUOTA_MONTH_TTL_SEC=3888000
AI_QUOTA_RESERVATION_TTL_SEC=600
AI_JOB_STATUS_TTL_SEC=1209600

# Next.js API gateway security/cors
API_SHARED_KEY=
API_CORS_ORIGINS=*
API_CORS_ALLOW_CREDENTIALS=false
API_HEALTHCHECK_TIMEOUT_MS=3000

LOCAL_STT_URL=http://127.0.0.1:8001/transcribe
STT_TIMEOUT_MS=180000
STT_MODEL_SIZE=small
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
# Optional on Windows GPU build: path with CUDA DLLs (e.g., torch/lib containing cublas/cudnn)
STT_CUDA_DLL_DIR=

LOCAL_TTS_URL=http://127.0.0.1:8002/synthesize
TTS_TIMEOUT_MS=240000
TTS_MAX_TEXT_LENGTH=1500
TTS_DEFAULT_LANGUAGE=ru
NEXT_PUBLIC_TALKINGHEAD_AVATAR_URL=/avatars/talkinghead.glb

LOCAL_AVATAR_URL=http://127.0.0.1:8003/render
AVATAR_TIMEOUT_MS=3600000

PIPER_EXE=C:\\piper\\piper.exe
PIPER_MODEL_RU=C:\\piper\\models\\ru\\denis\\ru_RU-denis-medium.onnx
PIPER_LENGTH_SCALE=1.04

LECTURE_DOC_PATH=Лекция №4-5 Внутренние и внешние метки ИАД.docx

PIPER_MODEL_RU_FALLBACKS=C:\\piper\\models\\ru\\denis\\ru_RU-denis-medium.onnx,C:\\piper\\models\\ru\\dmitri\\ru_RU-dmitri-medium.onnx,C:\\piper\\models\\ru\\ruslan\\ru_RU-ruslan-medium.onnx

AVATAR_ENGINE=musetalk
AVATAR_SOURCE_ASSET=C:\\Projects\\education_course\\program\\assets\\avatar\\teacher.png
# Legacy alias for backward compatibility. Prefer AVATAR_SOURCE_ASSET.
AVATAR_SOURCE_VIDEO=C:\\MuseTalk\\assets\\demo\\video1\\video1.png
AVATAR_RESULTS_DIR=runs
AVATAR_TIMEOUT_SEC=1200

MUSE_TALK_ROOT=C:\\MuseTalk
MUSE_TALK_PYTHON=C:\\MuseTalk\\.venv311\\Scripts\\python.exe
MUSE_TALK_VERSION=v15
MUSE_TALK_UNET_MODEL_PATH=C:\\MuseTalk\\models\\musetalkV15\\unet.pth
MUSE_TALK_UNET_CONFIG_PATH=C:\\MuseTalk\\models\\musetalkV15\\musetalk.json
MUSE_TALK_FFMPEG_PATH=C:\\ffmpeg\\bin
# Optional: use custom command template instead of default wrapper command.
# Placeholders: {config_path} {result_dir} {output_path} {source_path} {video_path} {audio_path} {root} {python} {version}
MUSE_TALK_COMMAND_TEMPLATE=

# CORS for local FastAPI services (local-stt/local-tts/local-avatar)
SERVICE_CORS_ORIGINS=*
SERVICE_CORS_ALLOW_CREDENTIALS=false
