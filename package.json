{
  "name": "course-ai-tutor-demo",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "prisma generate",
    "build": "cross-env NEXT_DIST_DIR=.next-build next build",
    "start": "cross-env NEXT_DIST_DIR=.next-build next start",
    "start:all": "powershell -ExecutionPolicy Bypass -File scripts/start-all.ps1",
    "stop:all": "powershell -ExecutionPolicy Bypass -File scripts/stop-all.ps1",
    "lint": "next lint",
    "db:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-postgres.ps1",
    "db:install-pgvector": "powershell -ExecutionPolicy Bypass -File scripts/install-pgvector.ps1",
    "redis:check": "powershell -ExecutionPolicy Bypass -File scripts/check-redis.ps1",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "test:api": "node scripts/api-smoke.mjs",
    "test:api:strict": "cross-env API_TEST_STRICT=true API_TEST_INCLUDE_AVATAR=true node scripts/api-smoke.mjs"
  },
  "dependencies": {
    "@met4citizen/talkinghead": "^1.7.0",
    "@prisma/client": "^6.16.2",
    "ioredis": "^5.10.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "next": "14.2.22",
    "openai": "^4.86.1",
    "pdf-parse": "^1.1.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "undici": "^6.23.0"
  },
  "devDependencies": {
    "@types/node": "22.15.0",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "cross-env": "7.0.3",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.22",
    "postcss": "8.4.47",
    "prisma": "^6.16.2",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.2"
  }
}
